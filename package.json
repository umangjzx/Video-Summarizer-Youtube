{
  "name": "youtube-mcp-server",
  "version": "1.0.0",
  "description": "Remote MCP server wrapping the YouTube Data API v3 for use as a Claude Cowork custom connector.",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "digest": "node scripts/digest.mjs",
    "tunnel": "concurrently -n server,ngrok -c blue,green \"npm start\" \"ngrok http --url=https://single-darkness-estrogen.ngrok-free.dev 8080\"",
    "watch": "node scripts/watchdog.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "pdfkit": "^0.19.1",
    "youtube-transcript": "^1.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
